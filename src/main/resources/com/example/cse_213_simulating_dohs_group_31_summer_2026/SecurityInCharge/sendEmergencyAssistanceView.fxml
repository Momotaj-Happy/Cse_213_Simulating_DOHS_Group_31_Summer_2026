<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="350.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cse_213_simulating_dohs_group_31_summer_2026.SecurityInCharge.Controller.sendEmergencyAssistanceController">
    <children>
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Send Emergency Assistance Request" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0" />
        <Label layoutX="30.0" layoutY="70.0" text="Current Location:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="70.0" />
        <TextField fx:id="txtCurrentLocation" layoutX="160.0" layoutY="65.0" prefHeight="25.0" prefWidth="180.0" promptText="Enter current location" AnchorPane.leftAnchor="160.0" AnchorPane.rightAnchor="160.0" AnchorPane.topAnchor="65.0" />
        <Label layoutX="30.0" layoutY="115.0" text="Description:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="115.0" />
        <TextArea fx:id="txtEmergencyDescription" layoutX="160.0" layoutY="110.0" prefHeight="80.0" prefWidth="180.0" promptText="Describe emergency details" AnchorPane.leftAnchor="160.0" AnchorPane.rightAnchor="160.0" AnchorPane.topAnchor="110.0" />
