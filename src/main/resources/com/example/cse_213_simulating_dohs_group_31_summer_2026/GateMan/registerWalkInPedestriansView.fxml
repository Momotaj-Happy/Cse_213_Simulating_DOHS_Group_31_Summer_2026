<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="350.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cse_213_simulating_dohs_group_31_summer_2026.GateMan.Controller.registerWalkInPedestriansController">
    <children>
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Register Walk-in Pedestrians" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0" />
        <Label layoutX="30.0" layoutY="70.0" text="Pedestrian Name:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="70.0" />
        <TextField fx:id="txtPedestrianName" layoutX="170.0" layoutY="65.0" prefHeight="25.0" prefWidth="160.0" promptText="Enter pedestrian name" AnchorPane.leftAnchor="170.0" AnchorPane.rightAnchor="170.0" AnchorPane.topAnchor="65.0" />
        <Label layoutX="30.0" layoutY="115.0" text="Identification Number:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="115.0" />
        <TextField fx:id="txtPedestrianIndent" layoutX="170.0" layoutY="110.0" prefHeight="25.0" prefWidth="160.0" promptText="Enter NID / ID number" AnchorPane.leftAnchor="170.0" AnchorPane.rightAnchor="170.0" AnchorPane.topAnchor="110.0" />
        <Label layoutX="30.0" layoutY="160.0" text="Time:" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="160.0" />
        <TextField fx:id="txtPedestrianTime" layoutX="170.0" layoutY="156.0" prefHeight="25.0" prefWidth="160.0" promptText="HH:MM" AnchorPane.leftAnchor="170.0" AnchorPane.rightAnchor="170.0" AnchorPane.topAnchor="156.0" />
        <Button layoutX="170.0" layoutY="210.0" onAction="#handleRegisterPedestrian" prefWidth="160.0" text="Register Pedestrian" AnchorPane.leftAnchor="170.0" AnchorPane.topAnchor="210.0" />
        <Label fx:id="lblPedestrianStatus" layoutX="30.0" layoutY="270.0" text="" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="270.0" />
    </children>
</AnchorPane>
