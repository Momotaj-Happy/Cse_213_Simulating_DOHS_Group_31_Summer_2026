<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="250.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cse_213_simulating_dohs_group_31_summer_2026.GateMan.Controller.toggleEmergencyBypassController">
    <children>
        <Label layoutX="30.0" layoutY="25.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Toggle Emergency Gate Bypass Mode" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="25.0" />
        <CheckBox fx:id="chkEmergencyOverride" layoutX="30.0" layoutY="75.0" onAction="#handleEmergencyOverrideToggle" text="Enable Emergency Gate Override" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="75.0" />
        <Button layoutX="30.0" layoutY="120.0" onAction="#handleProcessGateStatus" prefWidth="180.0" text="Process Gate Status" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="120.0" />
        <Label fx:id="lblEmergencyModeStatus" layoutX="30.0" layoutY="175.0" text="" AnchorPane.leftAnchor="30.0" AnchorPane.topAnchor="175.0" />
    </children>
</AnchorPane>
